# GitHub 仓库配置（构建时自动推导更新地址）
# 构建时推导:
#   FRONTEND_BUNDLE_URL → https://github.com/{owner}/{repo}/releases/latest/download/
#   RELEASE_URL         → https://github.com/{owner}/{repo}/releases
# 如需自定义（如自托管），可直接设置 FRONTEND_BUNDLE_URL / RELEASE_URL 覆盖
GITHUB_OWNER=zhougaopeng
GITHUB_REPO=desk-app-framework
